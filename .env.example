GEMINI_API_KEY=
TAVILY_API_KEY=
EUROPEANA_API_KEY=
PORT=3000

# ── Abuse / cost controls (all optional) ──
# Comma-separated browser origins allowed to call the API. Same-origin requests
# from the bundled frontend are always allowed.
# Default when unset: http://localhost:3000,http://127.0.0.1:3000
ALLOWED_ORIGINS=
# Per-IP budget for /api/* (defaults: 20 requests per 15 minutes)
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=900000
# Set to a long random string to require an X-API-Key header on /api/*.
# Leave blank to keep the public demo open.
API_ACCESS_TOKEN=
# Max upload size in bytes for /api/identify (default 6 MB)
MAX_UPLOAD_BYTES=6291456
